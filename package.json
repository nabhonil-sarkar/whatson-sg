{
  "name": "whatson-sg",
  "private": true,
  "version": "0.1.0",
  "description": "A Singapore events aggregator: website + app from one backend.",
  "workspaces": [
    "packages/*",
    "services/*",
    "apps/*"
  ],
  "scripts": {
    "db:init": "psql $DATABASE_URL -f db/schema.sql",
    "aggregate": "tsx services/aggregator/src/index.ts",
    "api": "tsx services/api/src/index.ts",
    "web": "next dev apps/web"
  },
  "devDependencies": {
    "tsx": "^4.22.4"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
